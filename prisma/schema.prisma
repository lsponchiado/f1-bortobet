generator client {
  provider = "prisma-client-js"
  previewFeatures = ["views"]
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum SessionType {
  PRACTICE_1
  PRACTICE_2
  PRACTICE_3
  SPRINT_QUALIFYING
  QUALIFYING
  SPRINT
  RACE
}

enum Category {
  STROLL
  HAAS
  HULKENBERG
}

model Driver {
  id                 Int                @id @default(autoincrement())
  firstName          String             @default("")
  lastName           String             @default("")
  code               String             @unique @db.Char(3)
  number             Int                @unique
  enabled            Boolean            @default(true)
  country            String
  headshotUrl        String?
  teamId             Int
  team               Team               @relation(fields: [teamId], references: [id])
  sessionEntries     SessionEntry[]
  betRaceGridItems   BetRaceGridItem[]
  betSprintGridItems BetSprintGridItem[]
}

model Team {
  id             Int            @id @default(autoincrement())
  name           String         @unique
  color          String
  country        String
  logoUrl        String?
  carUrl         String?
  drivers        Driver[]
  sessionEntries SessionEntry[]
}

model User {
  id         Int         @id @default(autoincrement())
  email      String      @unique
  username   String      @unique
  password   String
  name       String
  role       Role        @default(USER)
  category   Category    @default(HAAS)
  betRaces          BetRace[]
  betSprints        BetSprint[]
  betRaceResults    BetRaceResult[]
  betSprintResults  BetSprintResult[]
  inviteCode        InviteCode?
}

model Season {
  id          Int          @id @default(autoincrement())
  year        Int          @unique
  isActive    Boolean      @default(true)
  description String?
  sessions    Session[]
  config      SeasonConfig?
}

model SeasonConfig {
  id               Int    @id @default(autoincrement())
  seasonId         Int    @unique
  season           Season @relation(fields: [seasonId], references: [id])

  // Pontuação por posição (Top 10)
  ptsP1            Int  @default(25)
  ptsP2            Int  @default(18)
  ptsP3            Int  @default(15)
  ptsP4            Int  @default(12)
  ptsP5            Int  @default(10)
  ptsP6            Int  @default(8)
  ptsP7            Int  @default(6)
  ptsP8            Int  @default(4)
  ptsP9            Int  @default(2)
  ptsP10           Int  @default(1)

  // Mecânicas de bônus
  ptsHailMary      Int  @default(25)
  ptsUnderdog      Int  @default(10)
  ptsFreefall      Int  @default(5)
  ptsFastestLap    Int  @default(10)
  ptsSafetyCar     Int  @default(10)
  ptsDNF           Int  @default(10)

  // Pontuação da Sprint (Top 8)
  sprintPtsP1      Int  @default(8)
  sprintPtsP2      Int  @default(7)
  sprintPtsP3      Int  @default(6)
  sprintPtsP4      Int  @default(5)
  sprintPtsP5      Int  @default(4)
  sprintPtsP6      Int  @default(3)
  sprintPtsP7      Int  @default(2)
  sprintPtsP8      Int  @default(1)

  // Tokens de double points
  doublePointsTokens Int  @default(3)

  // Prêmios STROLL
  potStroll        Int  @default(800)   // valor pago por cada participante STROLL
  pctGps           Int  @default(75)    // % do pot total destinado aos GPs
  pctFinal         Int  @default(25)    // % do pot total destinado ao prêmio final

  // Distribuição por GP (P1/P2/P3, devem somar 100)
  gpPctP1          Int  @default(50)
  gpPctP2          Int  @default(30)
  gpPctP3          Int  @default(20)

  // Distribuição final da temporada (P1-P5, devem somar 100)
  finalPctP1       Int  @default(35)
  finalPctP2       Int  @default(25)
  finalPctP3       Int  @default(20)
  finalPctP4       Int  @default(12)
  finalPctP5       Int  @default(8)
}

model GrandPrix {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  country     String
  trackName   String
  trackMapUrl String?
  cancelled   Boolean   @default(false)
  sessions    Session[]
}

model Session {
  id          Int         @id @default(autoincrement())
  type        SessionType
  round       Int
  date        DateTime
  cancelled   Boolean     @default(false)
  openf1Key   Int?        @unique
  seasonId    Int
  grandPrixId Int
  season      Season      @relation(fields: [seasonId], references: [id])
  grandPrix   GrandPrix   @relation(fields: [grandPrixId], references: [id])
  raceConfig  RaceConfig?
  entries     SessionEntry[]
  betRaces          BetRace[]
  betSprints        BetSprint[]
  betRaceResults    BetRaceResult[]
  betSprintResults  BetSprintResult[]
  scCount           Int         @default(0)
  vscCount    Int         @default(0)

  @@unique([seasonId, grandPrixId, type])
  @@index([seasonId, grandPrixId])
}

model RaceConfig {
  id                Int     @id @default(autoincrement())
  sessionId         Int     @unique
  session           Session @relation(fields: [sessionId], references: [id])
  allowHailMary     Boolean @default(true)
  allowUnderdog     Boolean @default(true)
  allowFreefall     Boolean @default(true)
  allowSafetyCar    Boolean @default(true)
  allowDNF          Boolean @default(true)
  allowFastestLap   Boolean @default(true)
  allowDoublePoints Boolean @default(true)
  safetyCar         Int     @default(0)
}

model SessionEntry {
  id             Int     @id @default(autoincrement())
  sessionId      Int
  driverId       Int
  teamId         Int
  startPosition  Int     @default(99)
  finishPosition Int     @default(99)
  points         Float   @default(0)
  dns            Boolean @default(false)
  dnf            Boolean @default(false)
  dsq            Boolean @default(false)
  fastestLap     Boolean @default(false)
  session        Session @relation(fields: [sessionId], references: [id])
  driver         Driver  @relation(fields: [driverId], references: [id])
  team           Team    @relation(fields: [teamId], references: [id])

  @@unique([sessionId, driverId])
  @@index([sessionId])
}

model BetRace {
  id            Int               @id @default(autoincrement())
  userId        Int
  sessionId     Int
  driverId      Int?
  doublePoints  Boolean           @default(false)
  predictedSC   Int               @default(0)
  predictedDNF  Int               @default(0)
  createdAt     DateTime          @default(now())
  user          User              @relation(fields: [userId], references: [id])
  session       Session           @relation(fields: [sessionId], references: [id])
  predictedGrid BetRaceGridItem[]
  result        BetRaceResult?

  @@index([userId, sessionId])
}

model BetSprint {
  id            Int                 @id @default(autoincrement())
  userId        Int
  sessionId     Int
  createdAt     DateTime            @default(now())
  user          User                @relation(fields: [userId], references: [id])
  session       Session             @relation(fields: [sessionId], references: [id])
  predictedGrid BetSprintGridItem[]
  result        BetSprintResult?

  @@index([userId, sessionId])
}

model BetRaceGridItem {
  id                Int     @id @default(autoincrement())
  betId             Int
  driverId          Int
  predictedPosition Int
  fastestLap        Boolean @default(false)
  bet               BetRace @relation(fields: [betId], references: [id])
  driver            Driver  @relation(fields: [driverId], references: [id])

  @@unique([betId, predictedPosition])
}

model BetSprintGridItem {
  id                Int       @id @default(autoincrement())
  betId             Int
  driverId          Int
  predictedPosition Int
  bet               BetSprint @relation(fields: [betId], references: [id])
  driver            Driver    @relation(fields: [driverId], references: [id])

  @@unique([betId, predictedPosition])
}

/// Postgres VIEW – não gerenciada pelo Prisma Migrate
view BetRaceResult {
  id         Int   @unique
  betId      Int
  userId     Int
  sessionId  Int
  somaPos    Int[] /// pontos por posição (índice 0 = P1). 0 = errou, >0 = acertou
  hailMary   Int[] /// pontos de hail mary por posição. 0 = sem badge, >0 = badge
  underdog   Int[] /// pontos de underdog por posição. 0 = sem badge, >0 = badge
  freefall   Int[] /// pontos de freefall por posição. 0 = sem badge, >0 = badge
  fastestLap Int   @default(0)
  safetyCar  Int   @default(0)
  abandonos  Int   @default(0)
  somaTotal  Int   @default(0)

  bet     BetRace @relation(fields: [betId], references: [id])
  user    User    @relation(fields: [userId], references: [id])
  session Session @relation(fields: [sessionId], references: [id])

  @@unique([betId])
  @@map("bet_race_results_view")
}

/// Postgres VIEW – não gerenciada pelo Prisma Migrate
view BetSprintResult {
  id        Int   @unique
  betId     Int
  userId    Int
  sessionId Int
  somaPos   Int[] /// pontos por posição (índice 0 = P1). 0 = errou, >0 = acertou
  somaTotal Int   @default(0)

  bet     BetSprint @relation(fields: [betId], references: [id])
  user    User      @relation(fields: [userId], references: [id])
  session Session   @relation(fields: [sessionId], references: [id])

  @@unique([betId])
  @@map("bet_sprint_results_view")
}

model InviteCode {
  id        Int      @id @default(autoincrement())
  userId    Int?     @unique
  code      String   @unique
  used      Boolean  @default(false)
  category  Category @default(HAAS)
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
}
