generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum SessionType {
  PRACTICE_1
  PRACTICE_2
  PRACTICE_3
  SPRINT_QUALIFYING
  QUALIFYING
  SPRINT
  RACE
}

model Driver {
  id                 Int                @id @default(autoincrement())
  name               String             @unique
  code               String             @unique @db.Char(3)
  number             Int                @unique
  enabled            Boolean            @default(true)
  country            String
  headshotUrl        String?
  teamId             Int
  team               Team               @relation(fields: [teamId], references: [id])
  sessionEntries     SessionEntry[]
  betRaceGridItems   BetRaceGridItem[]
  betSprintGridItems BetSprintGridItem[]
  allInBets          BetRace[]          @relation("AllInDriver")
}

model Team {
  id             Int            @id @default(autoincrement())
  name           String         @unique
  color          String
  country        String
  logoUrl        String?
  carUrl         String?
  drivers        Driver[]
  sessionEntries SessionEntry[]
}

model User {
  id         Int         @id @default(autoincrement())
  email      String      @unique
  username   String      @unique
  password   String
  name       String
  category   String      @default("Haas")
  betRaces   BetRace[]
  betSprints BetSprint[]
  inviteCode InviteCode?
}

model Season {
  id          Int       @id @default(autoincrement())
  year        Int       @unique
  isActive    Boolean   @default(true)
  description String?
  sessions    Session[]
}

model GrandPrix {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  country     String
  trackName   String
  trackMapUrl String?
  sessions    Session[]
}

model Session {
  id          Int         @id @default(autoincrement())
  type        SessionType
  round       Int
  date        DateTime
  cancelled   Boolean     @default(false)
  openf1Key   Int?        @unique
  seasonId    Int
  grandPrixId Int
  season      Season      @relation(fields: [seasonId], references: [id])
  grandPrix   GrandPrix   @relation(fields: [grandPrixId], references: [id])
  raceConfig  RaceConfig?
  entries     SessionEntry[]
  betRaces    BetRace[]
  betSprints  BetSprint[]
  scCount     Int         @default(0)
  vscCount    Int         @default(0)

  @@unique([seasonId, grandPrixId, type])
}

model RaceConfig {
  id                Int     @id @default(autoincrement())
  sessionId         Int     @unique
  session           Session @relation(fields: [sessionId], references: [id])
  allowHailMary     Boolean @default(true)
  allowUnderdog     Boolean @default(true)
  allowFreefall     Boolean @default(true)
  allowAllIn        Boolean @default(true)
  allowSafetyCar    Boolean @default(true)
  allowDNF          Boolean @default(true)
  allowFastestLap   Boolean @default(true)
  allowDoublePoints Boolean @default(true)
  safetyCar         Int     @default(0)
}

model SessionEntry {
  id             Int     @id @default(autoincrement())
  sessionId      Int
  driverId       Int
  teamId         Int
  startPosition  Int     @default(99)
  finishPosition Int     @default(99)
  points         Float   @default(0)
  dns            Boolean @default(false)
  dnf            Boolean @default(false)
  dsq            Boolean @default(false)
  fastestLap     Boolean @default(false)
  session        Session @relation(fields: [sessionId], references: [id])
  driver         Driver  @relation(fields: [driverId], references: [id])
  team           Team    @relation(fields: [teamId], references: [id])

  @@unique([sessionId, driverId])
}

model BetRace {
  id            Int               @id @default(autoincrement())
  userId        Int
  sessionId     Int
  driverId      Int?
  doublePoints  Boolean           @default(false)
  allInDriver   Driver?           @relation("AllInDriver", fields: [driverId], references: [id])
  predictedSC   Int               @default(0)
  predictedDNF  Int               @default(0)
  createdAt     DateTime          @default(now())
  user          User              @relation(fields: [userId], references: [id])
  session       Session           @relation(fields: [sessionId], references: [id])
  predictedGrid BetRaceGridItem[]
}

model BetSprint {
  id            Int                 @id @default(autoincrement())
  userId        Int
  sessionId     Int
  createdAt     DateTime            @default(now())
  user          User                @relation(fields: [userId], references: [id])
  session       Session             @relation(fields: [sessionId], references: [id])
  predictedGrid BetSprintGridItem[]
}

model BetRaceGridItem {
  id                Int     @id @default(autoincrement())
  betId             Int
  driverId          Int
  predictedPosition Int
  fastestLap        Boolean @default(false)
  bet               BetRace @relation(fields: [betId], references: [id])
  driver            Driver  @relation(fields: [driverId], references: [id])

  @@unique([betId, predictedPosition])
}

model BetSprintGridItem {
  id                Int       @id @default(autoincrement())
  betId             Int
  driverId          Int
  predictedPosition Int
  bet               BetSprint @relation(fields: [betId], references: [id])
  driver            Driver    @relation(fields: [driverId], references: [id])

  @@unique([betId, predictedPosition])
}

model InviteCode {
  id        Int      @id @default(autoincrement())
  userId    Int?     @unique
  code      String   @unique
  used      Boolean  @default(false)
  category  String   @default("Haas")
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
}
